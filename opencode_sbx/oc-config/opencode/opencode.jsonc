{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": true
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer {env:GH_TOKEN}"
      }
    }
  },
  // permissions globales
  "permission": {
    // comportement par défaut pour les agents et les skills
    // peuvent être surchargés par des permissions d'agents
    "*": "ask",
    "edit": {
      "*": "ask"
    },
    // gestion des fichiers sensibles obligatoire si pas chiffrement !!!
    "read": {
      "*": "allow",
      ".env.*": "deny",
      ".env.schema": "allow"
    },
    "bash": {
      "*": "ask",
      "git diff*": "allow",
      "cat .env.*": "deny"
    },
    "task": "allow",
    "skill": {
      "*": "deny",
      "nuxt-ui": "allow"
    },
    "webfetch": "ask"
  },
  // plugins installés avec curl | sh ou npm npx, ...
  // les plugins homemade en .ts dans le dossier .config/opencode/plugins sont auto inclus
  "plugin": ["opencode-beads"],
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama Local",
      "options": {
        "baseURL": "https://ollama.local:3000/ollama/v1"
      },
      "models": {
        "qwen2.5-coder:7b": {
          "name": "qwen2.5-coder:7b"
        }
      }
    }
  }
}
